---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'
---

<footer class="mt-auto pt-9 md:pt-11 max-w-full text-foreground/80 flex justify-between">
  <div class="flex flex-col md:flex-row items-center justify-center">
    <span class="my-1">
      {siteConfig.author} © 2026
    </span>
    <span class="mx-5 hidden md:block"> :: </span>
    <span class="my-1">
      Powered by <a
        class="underline"
        target="_blank"
        rel="noopener noreferrer"
        href="https://astro.build">Astro</a
      >
      & <a
        class="underline"
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/stelcodes/multiterm-astro">MultiTerm</a
      >
    </span>
  </div>
  {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
</footer>
